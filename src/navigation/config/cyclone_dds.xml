<?xml version="1.0" encoding="UTF-8" ?>
<!--
  CycloneDDS static-peer discovery for 3 robots + 1 coordinator laptop.

  Strategy (matches setup_env.sh and infrastructure.launch.py):
    robot1 (agent1) lives in ROS_DOMAIN_ID 11   — 172.31.113.136
    robot2 (agent2) lives in ROS_DOMAIN_ID 12   — 172.31.89.63
    robot3 (agent3) lives in ROS_DOMAIN_ID 13   — 172.31.115.94
    coordinator     lives in ROS_DOMAIN_ID 10   — 172.31.78.102 (WSL laptop)

  A domain_bridge process on the coordinator joins each robot's private
  domain AND domain 10, bridging /robotN/odom inbound and
  /robotN/controller/cmd_vel outbound. That bridge needs SUBNET discovery
  on the laptop side, which is why the laptop is also a static peer of
  every robot.

  Set CYCLONEDDS_URI on every machine:
    export CYCLONEDDS_URI=file://$HOME/ros2_ws/src/navigation/config/cyclone_dds.xml
  (setup_env.sh already does this.)

  If the WSL laptop's WiFi IP changes (run `hostname -I` to confirm),
  update <Peer address="..."> below AND LAPTOP_IP in setup_env.sh.
-->
<CycloneDDS
  xmlns="https://cdds.io/config"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">

  <Domain id="any">
    <General>
      <!-- wlan0 on the Pis. On WSL the interface is typically eth0
           (the vEthernet adapter), so a second entry is added. CycloneDDS
           uses whichever exists. -->
      <Interfaces>
        <NetworkInterface name="wlan0" priority="default" multicast="default"/>
        <NetworkInterface name="eth0"  priority="default" multicast="default"/>
      </Interfaces>
      <AllowMulticast>false</AllowMulticast>
      <EnableMulticastLoopback>false</EnableMulticastLoopback>
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>

    <Discovery>
      <Peers>
        <Peer address="127.0.0.1"/>
        <Peer address="172.31.113.136"/> <!-- agent1 / robot1 -->
        <Peer address="172.31.89.63"/>   <!-- agent2 / robot2 -->
        <Peer address="172.31.115.94"/>  <!-- agent3 / robot3 -->
        <Peer address="172.31.78.102"/>  <!-- coordinator laptop (WSL) -->
      </Peers>
      <ParticipantIndex>auto</ParticipantIndex>
      <!-- domain_bridge joins two domains in one process and chews
           through participant slots — bump the cap. -->
      <MaxAutoParticipantIndex>60</MaxAutoParticipantIndex>
    </Discovery>

    <Tracing>
      <Verbosity>warning</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>
  </Domain>
</CycloneDDS>