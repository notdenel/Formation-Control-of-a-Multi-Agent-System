<?xml version="1.0" encoding="UTF-8" ?>
<!--
  CycloneDDS static-peer discovery for 3 robots + 1 WSL coordinator.

  Domain layout:
    robot1 (agent1)  ROS_DOMAIN_ID 11  172.31.113.136
    robot2 (agent2)  ROS_DOMAIN_ID 12  172.31.89.63
    robot3 (agent3)  ROS_DOMAIN_ID 13  172.31.115.94
    WSL coordinator  ROS_DOMAIN_ID 10  172.31.78.102

  Each robot runs domain_bridge (odom_bridge.launch.py) which joins both its
  private domain and domain 10 so /robotX/odom and /robotX/amcl_pose can be
  observed from WSL without broadcasting full scan/TF traffic.

  Set on every machine (or source setup_env.sh which does this):
    export CYCLONEDDS_URI=file://$HOME/ros2_ws/src/navigation/config/cyclone_dds.xml

  If any IP changes, update the <Peer> list here AND in setup_env.sh.
-->
<CycloneDDS
  xmlns="https://cdds.io/config"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">

  <Domain id="any">
    <General>
      <!-- autodetermine picks the first active non-loopback interface (wlan0) -->
      <Interfaces>
        <NetworkInterface autodetermine="true" priority="default" multicast="default"/>
      </Interfaces>
      <!-- Multicast disabled: rely solely on the static unicast peer list below -->
      <AllowMulticast>false</AllowMulticast>
      <EnableMulticastLoopback>false</EnableMulticastLoopback>
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>

    <Discovery>
      <!--
        All three robots + the WSL coordinator are listed on every machine.
        domain_bridge participants need to reach domain-10 peers (WSL) from
        the robots' private domains, so the WSL IP must be here.
      -->
      <Peers>
        <Peer address="127.0.0.1"/>          <!-- localhost / same-machine CLI -->
        <Peer address="172.31.113.136"/>      <!-- agent1 / robot1 -->
        <Peer address="172.31.89.63"/>        <!-- agent2 / robot2 -->
        <Peer address="172.31.115.94"/>       <!-- agent3 / robot3 -->
        <Peer address="172.31.78.102"/>       <!-- WSL coordinator -->
      </Peers>
      <ParticipantIndex>auto</ParticipantIndex>
      <!-- Raised from 32: domain_bridge joins multiple domains on the same host -->
      <MaxAutoParticipantIndex>60</MaxAutoParticipantIndex>
    </Discovery>

    <Tracing>
      <Verbosity>warning</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>
  </Domain>
</CycloneDDS>
