<?xml version="1.0" encoding="UTF-8" ?>
<!--
  CycloneDDS static peer discovery for 3 robots on a shared network.

  Static peer IPs for the current three-robot setup:
    agent1 / robot1: 172.31.113.136
    agent2 / robot2: 172.31.89.63
    agent3 / robot3: 172.31.115.94

  Set CYCLONEDDS_URI to the path of this file on each robot:
    export CYCLONEDDS_URI=file://$HOME/ros2_ws/src/navigation/config/cyclone_dds.xml
  Or source setup_env.sh which does this automatically.

  All three robots must be on the same ROS_DOMAIN_ID. This project currently
  standardizes on domain 10 because that was the last known working domain in
  earlier multi-robot tests. Domain 0 is also fine if every robot/terminal uses it.
-->
<CycloneDDS
  xmlns="https://cdds.io/config"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">

  <Domain id="any">
    <General>
      <!-- wlan0 is the active interface (eth0 has no carrier) -->
      <Interfaces>
        <NetworkInterface name="wlan0" priority="default" multicast="default"/>
      </Interfaces>
      <!-- Disable multicast — rely solely on static unicast peers below -->
      <AllowMulticast>false</AllowMulticast>
      <EnableMulticastLoopback>false</EnableMulticastLoopback>
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>

    <Discovery>
      <!--
        Static peer list for the current robot fleet.
        Keep this same file on all three robots. Including all three robot IPs on
        every robot is fine and avoids needing per-robot XML variants.

        If you run RViz or a centralized controller from a laptop on a multicast-
        blocked network, the laptop should also use this XML. If laptop discovery
        is still unreliable, add the laptop's current Wi-Fi IP here too.
      -->
      <Peers>
        <Peer address="127.0.0.1"/> <!-- localhost / same-machine CLI -->
        <Peer address="172.31.113.136"/> <!-- agent1 / robot1 -->
        <Peer address="172.31.89.63"/>  <!-- agent2 / robot2 -->
        <Peer address="172.31.115.94"/> <!-- agent3 / robot3 -->
      </Peers>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>32</MaxAutoParticipantIndex>
    </Discovery>

    <Tracing>
      <Verbosity>warning</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>
  </Domain>
</CycloneDDS>
