diff --git a/src/navigation/navigation/aggregation.py b/src/navigation/navigation/aggregation.py
--- a/src/navigation/navigation/aggregation.py
+++ b/src/navigation/navigation/aggregation.py
@@ -334,11 +334,34 @@
     namespaces = discovery.discover(timeout_sec=5.0)
     discovery.destroy_node()
 
-    if len(namespaces) < 2:
-        print(f'[aggregation] Need at least 2 robots, found {len(namespaces)}. Aborting.')
+    if len(namespaces) < 1:
+        print(f'[aggregation] No robots found. Aborting.')
         rclpy.shutdown()
         return
 
+    if len(namespaces) == 1:
+        ns = namespaces[0]
+        print(f'[aggregation] Only 1 robot found. Running cmd_vel smoke test on {ns}.')
+        smoke = rclpy.create_node('aggregation_smoke')
+        pub = smoke.create_publisher(Twist, f'{ns}/controller/cmd_vel', 10)
+        def smoke_pub():
+            t = Twist()
+            t.linear.x = 0.1
+            t.angular.z = 0.2
+            pub.publish(t)
+        smoke.create_timer(0.1, smoke_pub)
+        try:
+            rclpy.spin(smoke)
+        except KeyboardInterrupt:
+            stop = Twist()
+            for _ in range(10):
+                pub.publish(stop)
+                rclpy.spin_once(smoke, timeout_sec=0.05)
+        finally:
+            smoke.destroy_node()
+            rclpy.shutdown()
+        return
+
     print(f'\nStarting aggregation for: {" ↔ ".join(namespaces)}\n'
           f'Equilibrium distance: {GOAL_TOLERANCE:.3f} m\n')
 
